# ── Scraper ──────────────────────────────────────────────────────────────────
# Número máximo de resultados por busca (padrão: 30)
SCRAPER_MAX_RESULTS=30

# URL do webhook chamado após cada scraping (opcional)
WEBHOOK_URL=

# ── Evolution API (disparo WhatsApp) ─────────────────────────────────────────
# URL da sua instância da Evolution API (ex: https://evolution.seudominio.com)
EVOLUTION_API_URL=

# Chave de API gerada na Evolution API
EVOLUTION_API_KEY=

# Nome da instância criada na Evolution API (padrão: lead-hunter)
EVOLUTION_API_INSTANCE=lead-hunter
